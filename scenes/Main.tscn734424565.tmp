[sub_resource type="GDScript" id="GDScript_jlsqs"]
script/source = "extends Node2D

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if Manager.simulation_running:
		queue_redraw()
func _draw() -> void:
	var cell_size = Manager.cell_size
	
	for cell in Manager.live_density.keys():
		var  density = Manager.live_density[cell]
		# Ignore empty areas
		if density < 1.0:
			continue
		var color := Color.TRANSPARENT
# Define what the colors mean based on agent density
		if density < 3.0:
			color = Color(0, 1, 0, 0.3) # Green: Low Density / Smooth Flow
		elif density < 6.0:
			color = Color(1, 1, 0, 0.4) # Yellow: Medium / Slowing Down
		else:
			color = Color(1, 0, 0, 0.5) # Red: Critical Bottleneck

		# Draw the colored rectangle over that exact cell on the map
		var rect = Rect2(cell.x * cell_size, cell.y * cell_size, cell_size, cell_size)
		draw_rect(rect, color)
		
"

